    var d={todayRec:_data.todayRec,weekRec:_data.weekRec,todayPay:applyCoFilter(_data.todayPay),weekPay:applyCoFilter(_data.weekPay),overdueRec:_data.overdueRec,overduePay:applyCoFilter(_data.overduePay)};

    if(_currentTab==='today')html+=buildTodayHtml(d.todayRec,d.todayPay,d.overduePay);
    else if(_currentTab==='week')html+=buildWeekTable(d.weekRec,d.weekPay);
    else if(_currentTab==='overdue'){
      var sortedRec=(d.overdueRec||[]).slice().sort(function(a,b){return(a.daysDiff||0)-(b.daysDiff||0);});
      var sortedPay=(d.overduePay||[]).slice().sort(function(a,b){return(a.daysDiff||0)-(b.daysDiff||0);});

      html+='<div class="section-header"><span class="section-title">🔴 Overdue Receivables</span><span class="count-badge">'+sortedRec.length+'</span></div>';
      if(sortedRec.length)sortedRec.forEach(function(r){html+=recvCardHtml(r);});
      else html+='<div class="empty">No overdue receivables 🎉</div>';

      html+='<div class="section-header" style="margin-top:18px"><span class="section-title">🔴 Overdue Payables</span><span class="count-badge">'+sortedPay.length+'</span></div>';
      if(sortedPay.length){
        var totalOD=sortedPay.reduce(function(a,b){return a+(b.amount||0);},0);
        html+='<div class="pending-total-bar"><span>Total overdue payable</span><strong>'+fmt(totalOD)+'</strong></div>';
        sortedPay.forEach(function(p,i){html+=tickRowHtml(p,i,'odp');});
      }else html+='<div class="empty">No overdue payables 🎉</div>';
    }

    document.getElementById('content').innerHTML=html;
    if(_currentTab==='today')bindTodayPayAll();
  }

  var _partRowNum=0,_partSource='',_partSheetName=_MK_SHEET,_partAmount=0,_partRowId='';

  function openPartModal(rowNum,source,sheetName,company,amount,rowId){
    _partRowNum=rowNum;_partSource=source;_partSheetName=sheetName;_partAmount=amount;_partRowId=rowId;
    document.getElementById('partModalCompany').textContent=company+' ('+(source==='other'?'Other':sheetName)+')';
    document.getElementById('partModalPending').textContent='Total Due: '+fmt(amount);
    document.getElementById('partModalAmt').value='';
    document.getElementById('partModalConfirm').disabled=false;
    document.getElementById('partModalConfirm').textContent='✅ Confirm';
    document.getElementById('partModal').style.display='flex';
  }

  function closePartModal(){document.getElementById('partModal').style.display='none';}

  function submitPartPayment(){
    var amt=parseFloat(document.getElementById('partModalAmt').value);
    if(!amt||amt<=0){showToast('❌ Enter a valid amount');return;}
    if(amt>=_partAmount){showToast('❌ Use checkbox for full payment');return;}

    var btn=document.getElementById('partModalConfirm');btn.disabled=true;btn.textContent='⏳ Saving…';
    google.script.run.withSuccessHandler(function(res){
      if(res.success){
        closePartModal();showToast('💸 '+fmt(amt)+' payment recorded');
        var amtEl=document.getElementById('pamt-'+_partRowId);
        if(amtEl)amtEl.innerHTML=fmt(res.newAmount)+'<br><span style="font-size:10px;color:var(--muted);font-weight:600;text-decoration:line-through;">'+fmt(res.originalAmount||_partAmount)+'</span>';

        [_data.todayPay||[],_data.weekPay||[],_data.overduePay||[]].forEach(function(arr){
          arr.forEach(function(x){
            if(Number(x.rowNum)===Number(_partRowNum)&&String(x.source)===String(_partSource)&&String(x.sheetName||'')===String(_partSheetName||'')){
              x.gross=Number(res.originalAmount||x.gross||_partAmount);
              x.amount=Number(res.newAmount||x.amount);
              x.pending=Number(res.newAmount||x.pending);
            }
          });
        });

        addPaymentEntryToLocalHistory(_partSource,_partRowNum,_partSheetName,'',amt,'part');
        refreshLiveSummaries();
      }else{
        showToast('❌ '+res.error);btn.disabled=false;btn.textContent='✅ Confirm';
      }
    }).withFailureHandler(function(err){
      showToast('❌ '+err.message);btn.disabled=false;btn.textContent='✅ Confirm';
    }).recordPartPaymentPayable(_partRowNum,_partSource,amt,_partSheetName);
  }

  document.getElementById('partModal').addEventListener('click',function(e){if(e.target===this)closePartModal();});

  function switchTab(tab,el){
    _currentTab=tab;
    document.querySelectorAll('.tab').forEach(function(t){t.classList.remove('active');});
    el.classList.add('active');
    render();
  }

  function loadDashboard(){
    document.getElementById('content').innerHTML='<div class="empty">⏳ Loading...</div>';
    var doneMain=false,doneAcc=false;

    function tryRender(){
      if(!doneMain||!doneAcc)return;
      _MK_NAME=_data.companyMK||'MK';_RK_NAME=_data.companyRK||'RK';

      document.querySelectorAll('.lbl-mk').forEach(function(el){el.textContent=_MK_NAME;});
      document.querySelectorAll('.lbl-rk').forEach(function(el){el.textContent=_RK_NAME;});
      document.getElementById('coMK').textContent='🏭 '+_MK_NAME;
      document.getElementById('coRK').textContent='🏭 '+_RK_NAME;

      var k=_data.kpi;
      document.getElementById('kpiTodayRecv').innerText=fmt(k.todayExpectedReceiving);
      document.getElementById('kpiTodayPay').innerText=fmt(k.todayPaymentDue);
      document.getElementById('kpiOverAll').innerHTML=fmt(k.overdueReceivable)+'&nbsp;|&nbsp;'+fmt(k.overduePayable);
      document.getElementById('kpiWeek').innerHTML=fmt(k.weekReceivable)+'&nbsp;|&nbsp;'+fmt(k.weekPayable);
      document.getElementById('kpiMKToday').innerText=fmt(k.mkTodayDue);
      document.getElementById('kpiRKToday').innerText=fmt(k.rkTodayDue);
      document.getElementById('kpiMKOverdue').innerText=fmt(k.mkOverdue);
      document.getElementById('kpiRKOverdue').innerText=fmt(k.rkOverdue);
      document.getElementById('kpiMKWeek').innerText=fmt(k.mkWeekPayable);
      document.getElementById('kpiRKWeek').innerText=fmt(k.rkWeekPayable);
      document.getElementById('kpiOtherToday').innerText=fmt(k.otherTodayDue);
      document.getElementById('kpiOtherOverdue').innerText=fmt(k.otherOverdue);
      document.getElementById('kpiOtherWeek').innerHTML=fmt(k.otherWeekPayable)+'&nbsp;|&nbsp;'+fmt(k.purchaseWeekPayable);
      document.getElementById('kpiBankBal').innerText=fmt(_data.bankBalance||0);
      document.getElementById('kpiBankUpdated').innerText=_data.bankLastUpdated?'🕐 Updated: '+_data.bankLastUpdated:'';

      updatePaidKPIs();
      render();
    }  

    google.script.run.withSuccessHandler(function(data){
      _data=data;doneMain=true;tryRender();
    }).withFailureHandler(function(err){
      document.getElementById('content').innerHTML='<div class="error-box">❌ '+err.message+'</div>';
    }).getDashboardData();

    google.script.run.withSuccessHandler(function(data){
      _accountant=data||{allPayments:[]};doneAcc=true;tryRender();
    }).withFailureHandler(function(){
      _accountant={allPayments:[]};doneAcc=true;tryRender();
    }).getAccountantData();
  }

  window.onload=loadDashboard;
</script>
</body>

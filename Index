    else if(_paidPeriod==='month'){paidPurchase=(k.paidThisMonth||0)-(k.paidMonthOther||0);paidOther=k.paidMonthOther||0;paidMK=k.paidMonthMK||0;paidRK=k.paidMonthRK||0;paidCount='This Month';}

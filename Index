  function tickChanged(cb,rowNum,source,sheetName,company,rowId){
    if(!cb.checked)return;cb.disabled=true;
    serverMarkPaid(source,rowNum,sheetName,function(res){
      if(res.success){
        showToast('✅ '+company+' marked PAID');
        var row=document.getElementById(rowId);
        if(row){
          row.classList.remove('red-row','orange-row');row.classList.add('green-row');

    },function(err){showToast('❌ '+err.message);cb.checked=false;cb.disabled=false;});
  }

  function tickUndo(btn,rowNum,source,sheetName,company,rowId){
    if(!confirm('Undo payment for "'+company+'"?'))return;
    btn.textContent='⏳';btn.disabled=true;
    serverUndoPaid(source,rowNum,sheetName,function(res){
      if(res.success){
        showToast('↩️ '+company+' undone');
        var row=document.getElementById(rowId);
        if(row){
          row.classList.remove('green-row');row.classList.add('red-row');
          var amt=row.querySelector('.tick-amt');if(amt)amt.classList.remove('paid');
          var cb=row.querySelector('.tick-cb');if(cb){cb.checked=false;cb.disabled=false;}
          btn.remove();

          if(!row.querySelector('.tick-part')){
            var partBtn=document.createElement('button');
            partBtn.className='tick-part';
            partBtn.textContent='💰';
            partBtn.onclick=function(){
              var rowData=findLocalRow(rowNum,source,sheetName);
              var amtVal=rowData?Number(rowData.amount||0):0;
              openPartModal(rowNum,source,sheetName,company,amtVal,rowId);
            };
            var amtEl=row.querySelector('.tick-amt');
            if(amtEl&&amtEl.nextSibling)row.insertBefore(partBtn,amtEl.nextSibling);
            else row.appendChild(partBtn);
          }

        updateLocalStatus(rowNum,source,sheetName,'PENDING');
        removePaymentEntriesFromLocalHistory(rowNum,source,sheetName);
        refreshLiveSummaries();
      }else{showToast('❌ '+res.error);btn.textContent='↩️';btn.disabled=false;}
    },function(err){showToast('❌ '+err.message);btn.textContent='↩️';btn.disabled=false;});
  }

  function payAllToday(btn,items,rowIds){
    if(!items.length)return;
    if(!confirm('Mark ALL '+items.length+' pending payable(s) as PAID?'))return;
    btn.disabled=true;btn.textContent='⏳ Saving…';

    google.script.run.withSuccessHandler(function(res){
      if(res.success){
        showToast('✅ All payables marked PAID');

        items.forEach(function(it){
          updateLocalStatus(it.rowNum,it.source,it.sheetName,'PAID');
          var rowData=findLocalRow(it.rowNum,it.source,it.sheetName);
          addPaymentEntryToLocalHistory(it.source,it.rowNum,it.sheetName,'',rowData?Number(rowData.amount||0):0,'full');
        });

        rowIds.forEach(function(id){
          var row=document.getElementById(id);
          if(row){
            row.classList.remove('red-row','orange-row');
            row.classList.add('green-row');
            var cb=row.querySelector('.tick-cb');
            if(cb){cb.checked=true;cb.disabled=true;}
            var amt=row.querySelector('.tick-amt');
            if(amt)amt.classList.add('paid');
            var pb=row.querySelector('.tick-part');

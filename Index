<!DOCTYPE html>
<html>
<head>
  <base target="_top">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <style>
    :root {
      --ink:#0f172a; --success:#16a34a; --danger:#dc2626; --warning:#d97706;
      --info:#2563eb; --purple:#7c3aed; --orange:#ea580c; --teal:#0d9488;
      --bg:#f1f5f9; --card:#ffffff; --border:#e2e8f0; --muted:#64748b;
    }
    *{box-sizing:border-box;}
    body{font-family:-apple-system,BlinkMacSystemFont,sans-serif;background:var(--bg);margin:0;padding:12px;color:var(--ink);}
    .kpi-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:14px;}
    .kpi{background:var(--card);border-radius:14px;padding:12px 14px;box-shadow:0 1px 4px rgba(0,0,0,.08);border-top:4px solid #cbd5e1;}
    .kpi.recv{border-color:var(--success);}
    .kpi.pay{border-color:var(--info);}
    .kpi.over{border-color:var(--danger);}
    .kpi.week{border-color:var(--warning);}
    .kpi.bank{border-color:var(--purple);}
    .kpi.other{border-color:var(--orange);}
    .kpi.mk{border-color:#0891b2;}
    .kpi.rk{border-color:#7c3aed;}
    .kpi.paid{border-color:var(--teal);}
    .kpi h5{margin:0 0 4px;font-size:10px;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);font-weight:700;}
    .kpi h3{margin:0;font-size:1.05rem;font-weight:900;}
    .kpi h3.green{color:var(--success);}
    .kpi h3.red{color:var(--danger);}
    .kpi h3.blue{color:var(--info);}
    .kpi h3.amber{color:var(--warning);}
    .kpi h3.purple{color:var(--purple);}
    .kpi h3.orange{color:var(--orange);}
    .kpi h3.cyan{color:#0891b2;}
    .kpi h3.violet{color:#7c3aed;}
    .kpi h3.teal{color:var(--teal);}
    .kpi-updated{margin:4px 0 0;font-size:11px;color:var(--muted);font-weight:600;}
    .kpi-sub{margin:3px 0 0;font-size:11px;color:var(--muted);font-weight:600;}

    .paid-section-label{display:flex;align-items:center;gap:8px;background:var(--teal);color:white;border-radius:10px;padding:9px 14px;font-size:12px;font-weight:800;margin-bottom:8px;text-transform:uppercase;letter-spacing:.5px;}
    .paid-period-tabs{display:flex;gap:6px;margin-bottom:10px;}
    .paid-tab{flex:1;text-align:center;padding:8px 4px;border-radius:8px;font-size:11px;font-weight:700;cursor:pointer;color:var(--muted);background:var(--card);border:none;box-shadow:0 1px 3px rgba(0,0,0,.08);transition:all .2s;}
    .paid-tab.active{background:var(--teal);color:#fff;}

    .co-filter{display:flex;gap:8px;margin-bottom:14px;}
    .co-btn{flex:1;text-align:center;padding:10px 4px;border-radius:9px;font-size:12px;font-weight:700;cursor:pointer;color:var(--muted);background:var(--card);border:none;box-shadow:0 1px 3px rgba(0,0,0,.08);transition:all .2s;}
    .co-btn.active{background:var(--ink);color:#fff;}

    .tabs{display:flex;background:var(--card);border-radius:12px;padding:4px;margin-bottom:14px;gap:4px;box-shadow:0 1px 3px rgba(0,0,0,.08);}
    .tab{flex:1;text-align:center;padding:10px 4px;border-radius:9px;font-size:11px;font-weight:700;cursor:pointer;color:var(--muted);transition:all .2s;user-select:none;white-space:nowrap;}
    .tab.active{background:var(--ink);color:#fff;}

    .section-header{display:flex;justify-content:space-between;align-items:center;margin:16px 0 8px;}
    .section-title{font-size:13px;font-weight:800;color:var(--ink);text-transform:uppercase;letter-spacing:.5px;}
    .count-badge{font-size:11px;background:#e2e8f0;color:var(--muted);border-radius:20px;padding:2px 10px;font-weight:700;}

    .pay-all-bar{display:flex;align-items:center;justify-content:space-between;background:#fef2f2;border:1px solid #fecaca;border-radius:10px;padding:10px 14px;margin-bottom:12px;gap:8px;}
    .pay-all-bar span{font-size:12px;font-weight:700;color:var(--danger);}
    .btn-pay-all-today{background:var(--danger);border:none;color:white;font-weight:800;font-size:12px;padding:8px 16px;border-radius:8px;cursor:pointer;white-space:nowrap;}
    .btn-pay-all-today:disabled{opacity:.5;cursor:not-allowed;}

    .row-card{background:var(--card);border-radius:12px;padding:14px;margin-bottom:10px;border-left:5px solid #cbd5e1;box-shadow:0 1px 4px rgba(0,0,0,.06);transition:opacity .4s,transform .4s;}
    .green-row{border-left-color:var(--success);}
    .red-row{border-left-color:var(--danger);}
    .orange-row{border-left-color:var(--orange);}
    .row-card.paid-out{opacity:0;transform:translateX(40px);pointer-events:none;}

    .source-pill{font-size:9px;font-weight:800;padding:2px 7px;border-radius:4px;margin-left:6px;text-transform:uppercase;letter-spacing:.5px;}
    .pill-purchase{background:#dbeafe;color:#1d4ed8;}
    .pill-other{background:#ffedd5;color:#c2410c;}
    .firm-pill{font-size:9px;font-weight:800;padding:2px 6px;border-radius:4px;margin-left:4px;text-transform:uppercase;letter-spacing:.4px;}
    .firm-mk{background:#cffafe;color:#0e7490;}
    .firm-rk{background:#ede9fe;color:#5b21b6;}

    .row-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px;}
    .row-company{font-weight:800;font-size:.95rem;flex:1;margin-right:8px;display:flex;align-items:center;flex-wrap:wrap;gap:4px;}
    .status-badge{padding:3px 9px;border-radius:6px;color:white;font-size:10px;font-weight:800;white-space:nowrap;}
    .bg-paid{background:var(--success);}
    .bg-pending{background:var(--warning);}
    .data-line{display:flex;justify-content:space-between;align-items:center;font-size:12px;padding:3px 0;}
    .lbl{color:var(--muted);font-size:11px;font-weight:600;}
    .val{font-weight:700;}
    .val.danger{color:var(--danger);}
    .val.green{color:var(--success);}
    .divider{border:0;border-top:1px solid var(--border);margin:8px 0;}

    .day-tag{font-size:11px;font-weight:800;padding:2px 8px;border-radius:5px;}
    .overdue{color:var(--danger);background:#fee2e2;}
    .duetoday{color:var(--warning);background:#fef3c7;}
    .ontime{color:#64748b;background:#f1f5f9;}

    .tick-row{display:flex;align-items:center;gap:10px;padding:11px 14px;background:var(--card);border-radius:10px;margin-bottom:8px;box-shadow:0 1px 3px rgba(0,0,0,.06);border-left:4px solid #cbd5e1;transition:opacity .4s,transform .4s,background .3s;}
    .tick-row.red-row{border-left-color:var(--danger);}
    .tick-row.green-row{border-left-color:var(--success);opacity:.9;background:#f0fdf4;}
    .tick-row.orange-row{border-left-color:var(--orange);}
    .tick-row.paid-out{opacity:0;transform:translateX(40px);pointer-events:none;}

    .tick-cb{width:20px;height:20px;accent-color:var(--success);cursor:pointer;flex-shrink:0;}
    .tick-cb:disabled{cursor:not-allowed;opacity:.5;}
    .tick-info{flex:1;min-width:0;}
    .tick-name{font-weight:800;font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;display:flex;align-items:center;gap:4px;}
    .tick-meta{font-size:11px;color:var(--muted);font-weight:600;margin-top:2px;display:flex;gap:8px;flex-wrap:wrap;}
    .tick-amt{font-weight:900;font-size:13px;color:var(--danger);white-space:nowrap;flex-shrink:0;}
    .tick-amt.paid{color:var(--success);}
    .tick-undo{background:none;border:none;font-size:16px;cursor:pointer;padding:0 4px;flex-shrink:0;}
    .tick-part{background:var(--orange);border:none;color:white;font-size:13px;font-weight:800;padding:4px 8px;border-radius:7px;cursor:pointer;flex-shrink:0;}

    .actions{display:flex;gap:8px;margin-top:10px;}
    .btn{flex:1;text-align:center;padding:10px;border-radius:8px;color:white;font-weight:800;font-size:12px;text-decoration:none;display:flex;align-items:center;justify-content:center;gap:6px;cursor:pointer;border:none;}
    .btn-call{background:var(--info);}
    .btn-wa{background:var(--success);}

    .modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:200;display:flex;align-items:center;justify-content:center;padding:20px;}
    .modal-box{background:var(--card);border-radius:16px;padding:20px;width:100%;max-width:340px;box-shadow:0 8px 32px rgba(0,0,0,.2);}
    .modal-box h4{margin:0 0 4px;font-size:15px;font-weight:900;color:var(--ink);}
    .modal-box p{margin:0 0 14px;font-size:12px;color:var(--muted);font-weight:600;}
    .modal-input{width:100%;padding:12px 14px;border:2px solid var(--border);border-radius:10px;font-size:16px;font-weight:700;color:var(--ink);outline:none;margin-bottom:12px;}
    .modal-input:focus{border-color:var(--orange);}
    .modal-pending{font-size:12px;font-weight:700;color:var(--danger);margin-bottom:14px;}
    .modal-btns{display:flex;gap:8px;}
    .modal-btns button{flex:1;padding:11px;border:none;border-radius:9px;font-weight:800;font-size:13px;cursor:pointer;}
    .modal-confirm{background:var(--orange);color:white;}
    .modal-cancel{background:#e2e8f0;color:var(--ink);}
    .modal-confirm:disabled{opacity:.5;cursor:not-allowed;}

    .empty{text-align:center;padding:30px 20px;color:var(--muted);font-size:14px;}
    .error-box{background:#fee2e2;color:var(--danger);border-radius:10px;padding:14px;font-size:13px;font-weight:600;margin-bottom:12px;}
    .refresh-btn{display:block;width:100%;padding:12px;background:var(--ink);color:white;border:none;border-radius:10px;font-size:14px;font-weight:800;cursor:pointer;margin-bottom:14px;}

    .pending-section .tick-row{background:#fff8f8;}
    .pending-total-bar{display:flex;justify-content:space-between;align-items:center;background:#fef2f2;border:1px solid #fecaca;border-radius:10px;padding:10px 14px;margin-bottom:10px;}
    .pending-total-bar span{font-size:12px;font-weight:700;color:var(--danger);}
    .pending-total-bar strong{font-size:14px;font-weight:900;color:var(--danger);}

    .day-block{margin-bottom:18px;}
    .day-label{font-size:12px;font-weight:900;text-transform:uppercase;letter-spacing:1px;padding:7px 12px;border-radius:8px;margin-bottom:8px;display:flex;justify-content:space-between;align-items:center;}
    .today-label{background:var(--ink);color:white;}
    .normal-label{background:#e2e8f0;color:var(--ink);}
    .btn-pay-all{background:var(--danger);border-radius:7px;padding:6px 13px;color:white;font-weight:800;font-size:11px;border:none;cursor:pointer;white-space:nowrap;}
    .btn-pay-all:disabled{opacity:.5;cursor:not-allowed;}

    .mini-table{width:100%;border-collapse:collapse;background:var(--card);border-radius:10px;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.06);margin-bottom:4px;}
    .mini-table thead tr{background:#f8fafc;}
    .mini-table th{padding:8px 10px;font-size:10px;font-weight:800;color:var(--muted);text-align:left;text-transform:uppercase;border-bottom:1px solid var(--border);}
    .mini-table td{padding:9px 10px;font-size:12px;border-bottom:1px solid #f1f5f9;vertical-align:middle;transition:opacity .4s;}
    .mini-table tr:last-child td{border-bottom:none;}
    .mini-table tr.overdue-row td{background:#fff5f5;}
    .mini-table tr.row-paid-out td{opacity:0;pointer-events:none;}
    .mini-table .company-cell{font-weight:700;}
    .mini-table .amt-cell{font-weight:800;text-align:right;white-space:nowrap;}
    .mini-table .amt-cell.recv{color:var(--success);}
    .mini-table .amt-cell.pay{color:var(--info);}
    .mini-table .amt-cell.overdue{color:var(--danger);}
    .type-dot{display:inline-block;width:7px;height:7px;border-radius:50%;margin-right:5px;}
    .dot-recv{background:var(--success);}
    .dot-pay{background:var(--info);}
    .dot-other{background:var(--orange);}
    .dot-mk{background:#0891b2;}
    .dot-rk{background:#7c3aed;}

    .day-summary{display:flex;gap:8px;margin-bottom:8px;}
    .day-sum-pill{flex:1;background:var(--card);border-radius:8px;padding:8px 10px;box-shadow:0 1px 3px rgba(0,0,0,.06);}
    .day-sum-pill h6{margin:0 0 2px;font-size:10px;color:var(--muted);font-weight:700;text-transform:uppercase;}
    .day-sum-pill p{margin:0;font-size:13px;font-weight:900;}
    .day-sum-pill p.green{color:var(--success);}
    .day-sum-pill p.blue{color:var(--info);}

    #toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#1e293b;color:white;padding:12px 22px;border-radius:12px;font-size:13px;font-weight:700;opacity:0;transition:opacity .3s;pointer-events:none;z-index:999;white-space:nowrap;}
    #toast.show{opacity:1;}
  </style>
</head>
<body>

<div class="kpi-grid">
  <div class="kpi recv"><h5>📥 Today's Expected Receiving</h5><h3 class="green" id="kpiTodayRecv">₹ —</h3></div>
  <div class="kpi pay"><h5>📤 Today's Payment Due</h5><h3 class="blue" id="kpiTodayPay">₹ —</h3></div>
  <div class="kpi over" style="grid-column:1/-1"><h5>🔴 Overdue Receivables &nbsp;|&nbsp; 🔴 Overdue Payables</h5><h3 class="red" id="kpiOverAll">₹ — | ₹ —</h3></div>
  <div class="kpi week" style="grid-column:1/-1"><h5>📅 This Week — Receivable | Payable</h5><h3 class="amber" id="kpiWeek">₹ — | ₹ —</h3></div>
  <div class="kpi mk"><h5>🏭 <span class="lbl-mk">MK</span> — Today Due</h5><h3 class="cyan" id="kpiMKToday">₹ —</h3></div>
  <div class="kpi rk"><h5>🏭 <span class="lbl-rk">RK</span> — Today Due</h5><h3 class="violet" id="kpiRKToday">₹ —</h3></div>
  <div class="kpi mk"><h5>🔴 <span class="lbl-mk">MK</span> — Overdue</h5><h3 class="cyan" id="kpiMKOverdue">₹ —</h3></div>
  <div class="kpi rk"><h5>🔴 <span class="lbl-rk">RK</span> — Overdue</h5><h3 class="violet" id="kpiRKOverdue">₹ —</h3></div>
  <div class="kpi mk"><h5>📅 <span class="lbl-mk">MK</span> — This Week</h5><h3 class="cyan" id="kpiMKWeek">₹ —</h3></div>
  <div class="kpi rk"><h5>📅 <span class="lbl-rk">RK</span> — This Week</h5><h3 class="violet" id="kpiRKWeek">₹ —</h3></div>
  <div class="kpi other"><h5>📋 Other Pay — Today</h5><h3 class="orange" id="kpiOtherToday">₹ —</h3></div>
  <div class="kpi other"><h5>⚠️ Other Pay — Overdue</h5><h3 class="orange" id="kpiOtherOverdue">₹ —</h3></div>
  <div class="kpi other" style="grid-column:1/-1"><h5>📅 Other Pay — This Week &nbsp;|&nbsp; Purchase — This Week</h5><h3 class="orange" id="kpiOtherWeek">₹ — | ₹ —</h3></div>
  <div class="kpi bank" style="grid-column:1/-1"><h5>🏦 Bank Balance</h5><h3 class="purple" id="kpiBankBal">₹ —</h3><p class="kpi-updated" id="kpiBankUpdated"></p></div>

  <div style="grid-column:1/-1"><div class="paid-section-label">✅ Payments Made by Me</div></div>
  <div style="grid-column:1/-1">
    <div class="paid-period-tabs">
      <button class="paid-tab active" onclick="setPaidPeriod('all',this)">All Time</button>
      <button class="paid-tab" onclick="setPaidPeriod('month',this)">This Month</button>
      <button class="paid-tab" onclick="setPaidPeriod('week',this)">This Week</button>
      <button class="paid-tab" onclick="setPaidPeriod('today',this)">Today</button>
    </div>
  </div>

  <div class="kpi paid" style="grid-column:1/-1"><h5>✅ Total Paid — Purchase | Other</h5><h3 class="teal" id="kpiPaidTotal">₹ — | ₹ —</h3><p class="kpi-sub" id="kpiPaidCount"></p></div>
  <div class="kpi mk"><h5>✅ <span class="lbl-mk">MK</span> — Paid</h5><h3 class="cyan" id="kpiPaidMK">₹ —</h3></div>
  <div class="kpi rk"><h5>✅ <span class="lbl-rk">RK</span> — Paid</h5><h3 class="violet" id="kpiPaidRK">₹ —</h3></div>
  <div class="kpi other" style="grid-column:1/-1"><h5>✅ Other Payments — Paid</h5><h3 class="orange" id="kpiPaidOther">₹ —</h3></div>
</div>

<div class="co-filter">
  <button class="co-btn active" id="coAll" onclick="setCoFilter('all',this)">🏢 All</button>
  <button class="co-btn" id="coMK" onclick="setCoFilter('mk',this)">🏭 MK</button>
  <button class="co-btn" id="coRK" onclick="setCoFilter('rk',this)">🏭 RK</button>
</div>

<div class="tabs">
  <div class="tab active" onclick="switchTab('today',this)">📅 Today</div>
  <div class="tab" onclick="switchTab('week',this)">🗓 Week</div>
  <div class="tab" onclick="switchTab('overdue',this)">🔴 Overdue</div>
</div>

<button class="refresh-btn" onclick="loadDashboard()">🔄 Refresh</button>
<div id="content"><div class="empty">⏳ Loading...</div></div>
<div id="toast"></div>

<div id="partModal" class="modal-overlay" style="display:none">
  <div class="modal-box">
    <h4>💸 Part Payment</h4>
    <p id="partModalCompany">—</p>
    <div class="modal-pending" id="partModalPending"></div>
    <input type="number" class="modal-input" id="partModalAmt" placeholder="Enter amount to pay" min="1" inputmode="numeric">
    <div class="modal-btns">
      <button class="modal-cancel" onclick="closePartModal()">Cancel</button>
      <button class="modal-confirm" id="partModalConfirm" onclick="submitPartPayment()">✅ Confirm</button>
    </div>
  </div>
</div>

<script>
  var _data=null,_accountant=null,_currentTab='today',_coFilter='all',_paidPeriod='all';
  var _MK_SHEET='Purchase-MK',_RK_SHEET='Purchase-RK',_MK_NAME='MK',_RK_NAME='RK';
  var DAY_NAMES=['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  var MONTH_NAMES=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

  function fmt(n){return '₹ '+Math.round(n||0).toLocaleString('en-IN');}
  function pad(n){return String(n).padStart(2,'0');}
  function esc(s){return String(s).replace(/\\/g,'\\\\').replace(/'/g,"\\'");}
  function showToast(msg){var t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(function(){t.classList.remove('show');},2500);}

  function movePaidRowUp(rowId){
    var row=document.getElementById(rowId);
    if(!row)return;
    var allRows=Array.from(document.querySelectorAll('.tick-row'));
    if(!allRows.length)return;
    var firstPaidRow=allRows.find(function(r){return r.classList.contains('green-row');});
    if(firstPaidRow&&firstPaidRow!==row) row.parentNode.insertBefore(row,firstPaidRow);
    else row.parentNode.insertBefore(row,allRows[0]);
  }

  function dayTag(days,status){
    if(status==='PAID'||days===null||days===undefined)return '';
    if(days<0)return '<span class="day-tag overdue">'+Math.abs(days)+'d Overdue</span>';
    if(days===0)return '<span class="day-tag duetoday">Due Today</span>';
    return '<span class="day-tag ontime">'+days+'d Left</span>';
  }

  function parseDMY(str){
    if(!str)return '';
    str=String(str).trim();var m;
    m=str.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);if(m)return m[3]+'-'+pad(m[2])+'-'+pad(m[1]);
    m=str.match(/^(\d{1,2})\/(\d{1,2})\/(\d{2})$/);if(m)return (2000+parseInt(m[3],10))+'-'+pad(m[2])+'-'+pad(m[1]);
    m=str.match(/^(\d{1,2})-([A-Za-z]{3})-(\d{2,4})$/);
    if(m){var months={jan:'01',feb:'02',mar:'03',apr:'04',may:'05',jun:'06',jul:'07',aug:'08',sep:'09',oct:'10',nov:'11',dec:'12'};var yr=parseInt(m[3],10);if(yr<100)yr+=2000;return yr+'-'+(months[m[2].toLowerCase()]||'00')+'-'+pad(m[1]);}
    m=str.match(/^(\d{1,2})-(\d{1,2})-(\d{4})$/);if(m)return m[3]+'-'+pad(m[2])+'-'+pad(m[1]);
    return '';
  }

  function parseMDY(str){
    if(!str)return '';
    str=String(str).trim();var m;
    m=str.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);if(m)return m[3]+'-'+pad(m[1])+'-'+pad(m[2]);
    m=str.match(/^(\d{1,2})\/(\d{1,2})\/(\d{2})$/);if(m)return (2000+parseInt(m[3],10))+'-'+pad(m[1])+'-'+pad(m[2]);
    return parseDMY(str);
  }

  function parseDateBySource(str,source){return source==='other'?parseMDY(str):parseDMY(str);}
  function formatDateKey(d){return d.getFullYear()+'-'+pad(d.getMonth()+1)+'-'+pad(d.getDate());}
  function todayKey(){return formatDateKey(new Date());}
  function weekStartKey(){var d=new Date();d.setHours(0,0,0,0);var day=d.getDay();d.setDate(d.getDate()-day+(day===0?-6:1));return formatDateKey(d);}

  function sumPaidByRange(fromKey,toKey){
    if(!_accountant||!_accountant.allPayments)return{total:0,part:0,fullFinal:0,count:0};
    var rows=_accountant.allPayments.filter(function(p){
      var k=p.paidKey||'';if(!k||k==='unknown')return false;
      if(fromKey&&k<fromKey)return false;if(toKey&&k>toKey)return false;
      if(_coFilter==='mk')return p.source!=='purchase'||p.sheetName===_MK_SHEET;
      if(_coFilter==='rk')return p.source!=='purchase'||p.sheetName===_RK_SHEET;
      return true;
    });
    return{total:rows.reduce(function(a,b){return a+(b.amount||0);},0),count:rows.length};
  }

